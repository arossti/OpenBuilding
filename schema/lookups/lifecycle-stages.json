    "cradle_to_practical_completion": ["A1", "A2", "A3", "A4", "A5"],
    "cradle_to_grave":       ["A1", "A2", "A3", "A4", "A5", "B1", "B2", "B3", "B4", "B5", "B6", "B7", "C1", "C2", "C3", "C4"],
    "cradle_to_cradle":      ["A1", "A2", "A3", "A4", "A5", "B1", "B2", "B3", "B4", "B5", "B6", "B7", "C1", "C2", "C3", "C4", "D"]
  }
